# Discord
DISCORD_TOKEN=
CLIENT_ID=
GUILD_ID=

# Fallback channel
NEWS_CHANNEL_ID=

# Optional per-category channels, JSON
# Example: {"AI":"123456789","Frontend":"987654321","Backend":"111222333"}
NEWS_CHANNELS={}

# Database (Prisma)
DATABASE_URL="file:./dev.db"

# Scheduler interval in minutes
CHECK_INTERVAL_MINUTES=10

# Optional: run RSS fetch immediately on bot ready (useful for dev)
AUTO_RUN_ONCE=false

# Optional: Google Translate free endpoint for Indonesian translation
# Leave empty to disable. Example:
# TRANSLATE_API_URL="https://translate.googleapis.com/translate_a/single?client=gtx&sl=auto&tl=id&dt=t&q="
TRANSLATE_API_URL=